OPENAI_API_KEY=

PLANNER_MODEL=gpt-5.4-mini
ANSWER_MODEL=gpt-5.4-mini
JUDGE_MODEL=gpt-5.5

EMBEDDING_PROVIDER=local
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

CHROMA_PERSIST_DIRECTORY=artifacts/chroma/disney_reviews
CHROMA_COLLECTION_NAME=disney_reviews

PLANNER_TEMPERATURE=0
ANSWER_TEMPERATURE=0
JUDGE_TEMPERATURE=0

MIN_MONTH_REVIEWS=100
MIN_SEASON_REVIEWS=200
VISIT_SCORE_RATING_WEIGHT=0.45
VISIT_SCORE_LOW_NEGATIVE_WEIGHT=0.30
VISIT_SCORE_LOW_CROWDING_WEIGHT=0.25
